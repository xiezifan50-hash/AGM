{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sprint State",
  "type": "object",
  "required": [
    "task_id",
    "sprint_id",
    "sprint_number",
    "status",
    "phase",
    "user_request",
    "inheritance",
    "contract",
    "implementation",
    "reviews",
    "holistic_review",
    "next_sprint_seed",
    "resume_from",
    "timestamps"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "sprint_id": { "type": "string" },
    "sprint_number": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["in_progress", "paused", "done", "carry_forward", "blocked", "aborted"]
    },
    "phase": { "type": "string" },
    "user_request": { "type": "string" },
    "inheritance": {
      "type": "object",
      "required": [
        "from_sprint_number",
        "accepted_features_inherited",
        "open_findings_inherited",
        "rejected_findings_inherited",
        "canonical_context"
      ],
      "properties": {
        "from_sprint_number": { "type": ["integer", "null"] },
        "accepted_features_inherited": { "type": "array", "items": { "$ref": "#/$defs/featureState" } },
        "open_findings_inherited": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "rejected_findings_inherited": { "type": "array", "items": { "$ref": "#/$defs/rejectedFinding" } },
        "canonical_context": {
          "type": "object",
          "required": ["summary_zh", "artifact_index"],
          "properties": {
            "summary_zh": { "type": "string" },
            "artifact_index": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "contract": {
      "type": "object",
      "required": [
        "generator_research",
        "evaluator_research",
        "negotiation_rounds",
        "feature_consensus",
        "global_consensus",
        "holistic_rubric",
        "accepted_contract",
        "unresolved_points",
        "human_intervention"
      ],
      "properties": {
        "generator_research": { "type": ["object", "null"] },
        "evaluator_research": { "type": ["object", "null"] },
        "negotiation_rounds": { "type": "array", "items": { "$ref": "#/$defs/negotiationRound" } },
        "feature_consensus": { "type": "array", "items": { "$ref": "#/$defs/featureConsensus" } },
        "global_consensus": {
          "type": "object",
          "required": ["pass", "unresolved_points_zh", "missing_fields"],
          "properties": {
            "pass": { "type": "boolean" },
            "unresolved_points_zh": { "type": "array", "items": { "type": "string" } },
            "missing_fields": { "type": "array", "items": { "type": "string" } }
          }
        },
        "holistic_rubric": { "$ref": "#/$defs/holisticRubric" },
        "accepted_contract": { "type": ["object", "null"] },
        "unresolved_points": { "type": "array", "items": { "$ref": "#/$defs/unresolvedPoint" } },
        "human_intervention": {
          "type": "object",
          "required": ["required", "reason_zh", "decisions"],
          "properties": {
            "required": { "type": "boolean" },
            "reason_zh": { "type": "string" },
            "decisions": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "implementation": {
      "type": "object",
      "required": ["feature_queue", "current_feature_id", "features", "changed_files", "l1_checks"],
      "properties": {
        "feature_queue": { "type": "array", "items": { "type": "string" } },
        "current_feature_id": { "type": ["string", "null"] },
        "features": { "type": "array", "items": { "$ref": "#/$defs/featureExecution" } },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "l1_checks": { "type": "array", "items": { "$ref": "#/$defs/l1Check" } }
      }
    },
    "reviews": {
      "type": "object",
      "required": ["review_jobs", "feature_reviews", "dimension_reviews", "aggregate"],
      "properties": {
        "review_jobs": { "type": "array", "items": { "$ref": "#/$defs/reviewJob" } },
        "feature_reviews": { "type": "array", "items": { "$ref": "#/$defs/reviewVerdict" } },
        "dimension_reviews": { "type": "array", "items": { "$ref": "#/$defs/reviewVerdict" } },
        "aggregate": {
          "type": "object",
          "required": ["all_required_passed", "open_findings"],
          "properties": {
            "all_required_passed": { "type": "boolean" },
            "open_findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } }
          }
        }
      }
    },
    "holistic_review": {
      "type": "object",
      "required": ["pass", "summary_zh", "satisfaction_gaps_zh", "carry_forward_required", "rejected_review_findings", "decision_basis"],
      "properties": {
        "pass": { "type": ["boolean", "null"] },
        "summary_zh": { "type": "string" },
        "satisfaction_gaps_zh": { "type": "array", "items": { "type": "string" } },
        "carry_forward_required": { "type": "array", "items": { "type": "string" } },
        "rejected_review_findings": { "type": "array", "items": { "$ref": "#/$defs/rejectedFinding" } },
        "decision_basis": { "$ref": "#/$defs/holisticDecisionBasis" }
      }
    },
    "next_sprint_seed": {
      "type": "object",
      "required": [
        "should_create_next_sprint",
        "accepted_features_inherited",
        "open_features",
        "open_findings",
        "rejected_findings",
        "canonical_context"
      ],
      "properties": {
        "should_create_next_sprint": { "type": "boolean" },
        "accepted_features_inherited": { "type": "array", "items": { "$ref": "#/$defs/featureState" } },
        "open_features": { "type": "array", "items": { "$ref": "#/$defs/featureState" } },
        "open_findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "rejected_findings": { "type": "array", "items": { "$ref": "#/$defs/rejectedFinding" } },
        "canonical_context": { "type": "string" }
      }
    },
    "resume_from": {
      "type": "object",
      "required": ["phase", "pending_actor", "reason_zh"],
      "properties": {
        "phase": { "type": "string" },
        "pending_actor": { "type": ["string", "null"] },
        "reason_zh": { "type": "string" }
      }
    },
    "timestamps": {
      "type": "object",
      "required": ["created_at", "updated_at"],
      "properties": {
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    }
  },
  "$defs": {
    "featureState": {
      "type": "object",
      "required": ["feature_id", "title_zh", "status", "notes_zh"],
      "properties": {
        "feature_id": { "type": "string" },
        "title_zh": { "type": "string" },
        "status": { "type": "string" },
        "notes_zh": { "type": "string" }
      }
    },
    "acceptanceCriteria": {
      "type": "object",
      "required": ["feature_id", "criteria_zh"],
      "properties": {
        "feature_id": { "type": "string" },
        "criteria_zh": { "type": "array", "items": { "type": "string" } }
      }
    },
    "l1CheckSpec": {
      "type": "object",
      "required": ["check_id", "name_zh", "command", "required"],
      "properties": {
        "check_id": { "type": "string" },
        "name_zh": { "type": "string" },
        "command": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "rejectedRequest": {
      "type": "object",
      "required": ["request_id", "reason_zh"],
      "properties": {
        "request_id": { "type": "string" },
        "reason_zh": { "type": "string" }
      }
    },
    "holisticRubric": {
      "type": "object",
      "required": [
        "user_success_statement_zh",
        "must_have_features",
        "nice_to_have_features",
        "holistic_acceptance_criteria_zh",
        "holistic_fail_conditions_zh",
        "deferred_concerns_zh",
        "rejected_evaluator_requests"
      ],
      "properties": {
        "user_success_statement_zh": { "type": "string" },
        "must_have_features": { "type": "array", "items": { "type": "string" } },
        "nice_to_have_features": { "type": "array", "items": { "type": "string" } },
        "holistic_acceptance_criteria_zh": { "type": "array", "items": { "type": "string" } },
        "holistic_fail_conditions_zh": { "type": "array", "items": { "type": "string" } },
        "deferred_concerns_zh": { "type": "array", "items": { "type": "string" } },
        "rejected_evaluator_requests": { "type": "array", "items": { "$ref": "#/$defs/rejectedRequest" } }
      }
    },
    "contractDoc": {
      "type": "object",
      "required": [
        "summary_zh",
        "features_planned",
        "acceptance_criteria",
        "non_goals_zh",
        "l1_checks",
        "review_dimensions",
        "risks_zh",
        "user_success_statement_zh",
        "must_have_features",
        "nice_to_have_features",
        "holistic_acceptance_criteria_zh",
        "holistic_fail_conditions_zh",
        "deferred_concerns_zh",
        "rejected_evaluator_requests"
      ],
      "properties": {
        "summary_zh": { "type": "string" },
        "features_planned": { "type": "array", "items": { "$ref": "#/$defs/featurePlan" } },
        "acceptance_criteria": { "type": "array", "items": { "$ref": "#/$defs/acceptanceCriteria" } },
        "non_goals_zh": { "type": "array", "items": { "type": "string" } },
        "l1_checks": { "type": "array", "items": { "$ref": "#/$defs/l1CheckSpec" } },
        "review_dimensions": { "type": "array", "items": { "type": "string" } },
        "risks_zh": { "type": "array", "items": { "type": "string" } },
        "user_success_statement_zh": { "type": "string" },
        "must_have_features": { "type": "array", "items": { "type": "string" } },
        "nice_to_have_features": { "type": "array", "items": { "type": "string" } },
        "holistic_acceptance_criteria_zh": { "type": "array", "items": { "type": "string" } },
        "holistic_fail_conditions_zh": { "type": "array", "items": { "type": "string" } },
        "deferred_concerns_zh": { "type": "array", "items": { "type": "string" } },
        "rejected_evaluator_requests": { "type": "array", "items": { "$ref": "#/$defs/rejectedRequest" } }
      }
    },
    "featurePlan": {
      "type": "object",
      "required": ["feature_id", "title_zh", "reason_zh"],
      "properties": {
        "feature_id": { "type": "string" },
        "title_zh": { "type": "string" },
        "reason_zh": { "type": "string" }
      }
    },
    "unresolvedPoint": {
      "type": "object",
      "required": ["point_id", "kind", "target_id", "title_zh", "generator_position_zh", "evaluator_position_zh"],
      "properties": {
        "point_id": { "type": "string" },
        "kind": { "type": "string", "enum": ["feature", "global"] },
        "target_id": { "type": "string" },
        "title_zh": { "type": "string" },
        "generator_position_zh": { "type": "string" },
        "evaluator_position_zh": { "type": "string" }
      }
    },
    "negotiationRound": {
      "type": "object",
      "required": [
        "round_number",
        "generator_proposal",
        "evaluator_feedback",
        "generator_argue_back",
        "evaluator_resolution",
        "round_status"
      ],
      "properties": {
        "round_number": { "type": "integer", "minimum": 1 },
        "generator_proposal": { "$ref": "#/$defs/contractDoc" },
        "evaluator_feedback": { "$ref": "#/$defs/contractFeedback" },
        "generator_argue_back": { "$ref": "#/$defs/contractResolution" },
        "evaluator_resolution": { "$ref": "#/$defs/contractFeedback" },
        "round_status": { "type": "string" }
      }
    },
    "contractFeedback": {
      "type": "object",
      "required": [
        "summary_zh",
        "pass",
        "issues_zh",
        "suggested_edits_zh",
        "challenge_points_zh",
        "proposed_holistic_acceptance_criteria_zh",
        "proposed_holistic_fail_conditions_zh",
        "deferred_concerns_zh"
      ],
      "properties": {
        "summary_zh": { "type": "string" },
        "pass": { "type": "boolean" },
        "issues_zh": { "type": "array", "items": { "type": "string" } },
        "suggested_edits_zh": { "type": "array", "items": { "type": "string" } },
        "challenge_points_zh": { "type": "array", "items": { "type": "string" } },
        "proposed_holistic_acceptance_criteria_zh": { "type": "array", "items": { "type": "string" } },
        "proposed_holistic_fail_conditions_zh": { "type": "array", "items": { "type": "string" } },
        "deferred_concerns_zh": { "type": "array", "items": { "type": "string" } }
      }
    },
    "contractResolution": {
      "type": "object",
      "required": ["summary_zh", "accepted_changes_zh", "rejected_evaluator_requests", "unresolved_points", "resolved_contract"],
      "properties": {
        "summary_zh": { "type": "string" },
        "accepted_changes_zh": { "type": "array", "items": { "type": "string" } },
        "rejected_evaluator_requests": { "type": "array", "items": { "$ref": "#/$defs/rejectedRequest" } },
        "unresolved_points": { "type": "array", "items": { "$ref": "#/$defs/unresolvedPoint" } },
        "resolved_contract": { "$ref": "#/$defs/contractDoc" }
      }
    },
    "featureConsensus": {
      "type": "object",
      "required": ["feature_id", "title_zh", "pass", "agreed_acceptance_criteria_zh", "unresolved_points_zh"],
      "properties": {
        "feature_id": { "type": "string" },
        "title_zh": { "type": "string" },
        "pass": { "type": "boolean" },
        "agreed_acceptance_criteria_zh": { "type": "array", "items": { "type": "string" } },
        "unresolved_points_zh": { "type": "array", "items": { "type": "string" } }
      }
    },
    "featureExecution": {
      "type": "object",
      "required": ["feature_id", "summary_zh", "research_summary_zh", "execution_summary_zh", "status", "changed_files", "blockers_zh", "attempts"],
      "properties": {
        "feature_id": { "type": "string" },
        "summary_zh": { "type": "string" },
        "research_summary_zh": { "type": "string" },
        "execution_summary_zh": { "type": "string" },
        "status": { "type": "string", "enum": ["in_progress", "l1_failed", "passed", "blocked"] },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "blockers_zh": { "type": "array", "items": { "type": "string" } },
        "attempts": { "type": "integer", "minimum": 1 }
      }
    },
    "l1Check": {
      "type": "object",
      "required": ["feature_id", "check_id", "name_zh", "command", "required", "pass", "evidence_zh"],
      "properties": {
        "feature_id": { "type": "string" },
        "check_id": { "type": "string" },
        "name_zh": { "type": "string" },
        "command": { "type": "string" },
        "required": { "type": "boolean" },
        "pass": { "type": "boolean" },
        "evidence_zh": { "type": "string" }
      }
    },
    "reviewJob": {
      "type": "object",
      "required": ["review_id", "scope_type", "scope_id", "status"],
      "properties": {
        "review_id": { "type": "string" },
        "scope_type": { "type": "string", "enum": ["feature", "dimension"] },
        "scope_id": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "reviewVerdict": {
      "type": "object",
      "required": ["review_id", "scope_type", "scope_id", "pass", "severity", "score", "score_reason_zh", "project_path", "review_dimension_zh", "summary_zh", "evidence_sections", "findings"],
      "properties": {
        "review_id": { "type": "string" },
        "scope_type": { "type": "string", "enum": ["feature", "dimension"] },
        "scope_id": { "type": "string" },
        "pass": { "type": "boolean" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "score": { "type": "integer", "enum": [0, 1, 2, 3, 4, 5] },
        "score_reason_zh": { "type": "string" },
        "project_path": { "type": "string" },
        "review_dimension_zh": { "type": "string" },
        "summary_zh": { "type": "string" },
        "evidence_sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["section_id", "title_zh", "result", "evidence_zh", "references"],
            "properties": {
              "section_id": { "type": "string" },
              "title_zh": { "type": "string" },
              "result": { "type": "string", "enum": ["pass", "warning", "fail", "info"] },
              "evidence_zh": { "type": "string" },
              "references": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["kind", "target"],
                  "properties": {
                    "kind": { "type": "string", "enum": ["file", "command", "log", "diff", "other"] },
                    "target": { "type": "string" },
                    "detail_zh": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } }
      }
    },
    "finding": {
      "type": "object",
      "required": ["finding_id", "severity", "summary_zh", "evidence_zh", "repro_steps_zh", "suggested_fix_zh"],
      "properties": {
        "finding_id": { "type": "string" },
        "scope_type": { "type": "string" },
        "scope_id": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "summary_zh": { "type": "string" },
        "evidence_zh": { "type": "string" },
        "repro_steps_zh": { "type": "array", "items": { "type": "string" } },
        "suggested_fix_zh": { "type": "string" }
      }
    },
    "rejectedFinding": {
      "type": "object",
      "required": ["finding_id", "reason_zh"],
      "properties": {
        "finding_id": { "type": "string" },
        "reason_zh": { "type": "string" }
      }
    },
    "holisticDecisionBasis": {
      "type": "object",
      "required": ["unmet_acceptance_criteria_zh", "triggered_fail_conditions_zh", "emergent_blockers"],
      "properties": {
        "unmet_acceptance_criteria_zh": { "type": "array", "items": { "type": "string" } },
        "triggered_fail_conditions_zh": { "type": "array", "items": { "type": "string" } },
        "emergent_blockers": { "type": "array", "items": { "$ref": "#/$defs/emergentBlocker" } }
      }
    },
    "emergentBlocker": {
      "type": "object",
      "required": ["blocker_id", "severity", "reason_zh", "why_now_zh", "should_promote_to_contract", "next_negotiation_hint_zh"],
      "properties": {
        "blocker_id": { "type": "string" },
        "severity": { "type": "string", "enum": ["high", "critical"] },
        "reason_zh": { "type": "string" },
        "why_now_zh": { "type": "string" },
        "should_promote_to_contract": { "type": "boolean" },
        "next_negotiation_hint_zh": { "type": "string" }
      }
    }
  }
}
